# SURI — 환경 변수 템플릿
# 
# 사용법: 이 파일을 .env로 복사한 뒤 값을 채우세요.
#   cp .env.example .env
#
# .env 파일은 .gitignore 처리되어 있습니다 (커밋 금지).

# =============================================================
# Anthropic API
# =============================================================
# 발급: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# =============================================================
# PostgreSQL — Admin (데이터 로딩용)
# =============================================================
# docker-compose.yml 초기 설정과 일치해야 함
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=suri
POSTGRES_USER=suri_admin
POSTGRES_PASSWORD=changeme

# =============================================================
# PostgreSQL — Readonly (MCP 서버용, Layer 2 방어)
# =============================================================
# data/schema/002_pii.sql의 CREATE ROLE 비밀번호와 일치해야 함
# 기본값: suri_readonly / readonly_pass (PoC 전용 — 운영 이관 시 secret manager)
POSTGRES_READONLY_USER=suri_readonly
POSTGRES_READONLY_PASSWORD=readonly_pass
